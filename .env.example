# ─────────────────────────────────────────────────────────────────────────────
# Warden configuration. Copy to `.env` and fill in to enable LIVE mode.
# With NO values set, Warden runs fully in SIMULATION mode (no cloud needed).
# ─────────────────────────────────────────────────────────────────────────────

# --- Run mode -----------------------------------------------------------------
# "sim"  -> mock Dynatrace + scripted brain (default, zero credentials)
# "live" -> real Dynatrace MCP server + Gemini brain (requires the vars below)
WARDEN_MODE=sim

# --- Gemini / Vertex AI (Warden's brain) --------------------------------------
# The hackathon requires the agent be Gemini-powered.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
WARDEN_GEMINI_MODEL=gemini-flash-latest
# Flash is the default so the brain runs on the AI Studio free tier.
# Switch to gemini-pro-latest when you have Vertex (paid) quota.
WARDEN_GEMINI_REASONING_MODEL=gemini-flash-latest
# Or, for AI Studio key-based auth instead of Vertex:
# GOOGLE_GENAI_USE_VERTEXAI=false
# GOOGLE_API_KEY=your-aistudio-key

# --- Dynatrace MCP server (Warden's senses) -----------------------------------
# Spin up a free tenant at https://www.dynatrace.com/signup/
DT_ENVIRONMENT=https://abc12345.apps.dynatrace.com
DT_PLATFORM_TOKEN=
# OAuth alternative:
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# Cap Grail scan cost per session (GB):
DT_GRAIL_QUERY_BUDGET_GB=50

# --- OpenTelemetry export to Dynatrace (live mode) ----------------------------
# Worker agents mirror their telemetry as OTel spans + metrics to your tenant
# so Davis can baseline the fleet and raise real problems Warden then reads
# back via MCP. Without these set, Warden runs identically but emits no OTel.
#
# IMPORTANT: the OTLP gateway lives on the CLASSIC `.live.dynatrace.com` host
# even when your Platform UI is at `.apps.dynatrace.com`. Warden auto-translates
# from the apps host to the live host, so DT_ENVIRONMENT can stay as your UI URL.
# Override here if you need a custom OTLP endpoint:
DT_OTLP_ENDPOINT=
#
# Auth: the OTLP API is the classic Environment API and ONLY accepts classic
# Api-Tokens. The required scopes are:
#   openTelemetryTrace.ingest
#   metrics.ingest
#   logs.ingest
# These scopes do NOT appear in the Personal Platform token dropdown. Generate
# a CLASSIC Dynatrace access token here:
#   https://xwy37883.live.dynatrace.com/ui/apps/dynatrace.classic.tokens
# (replace `xwy37883` with your tenant ID). Then set:
DT_API_TOKEN=
#
# Optional bearer fallback (only works with rare Platform tokens that explicitly
# carry the three OTLP scopes; most do not):
DT_OTEL_BEARER=

# --- Optional: Slack notifications for interventions --------------------------
SLACK_WEBHOOK_URL=

# --- Privacy controls ---------------------------------------------------------
# Hard kill switch: force ScriptedBrain even in live mode. Use when even
# aggregate signals (problem metadata, fleet rollups) cannot leave the perimeter.
WARDEN_DISABLE_GENERATIVE=false
# Append-only audit log of every Gemini call: ts, model, sha256 hashes, byte
# sizes, dropped allowlist fields. Never raw content. Empty string disables.
WARDEN_AUDIT_LOG=warden_audit.log

# --- Web dashboard ------------------------------------------------------------
WARDEN_WEB_HOST=127.0.0.1
WARDEN_WEB_PORT=8080
